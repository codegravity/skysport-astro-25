---
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import WindLinks from "@components/elements/windlinks.astro";
import { Icon } from 'astro-icon/components';
interface VideoContent {
  title?: string;
  description?: string;
  descriptionImage?: ImageMetadata;
  backgroundVideo?: string;
  mobileVideo?: string;
  tabVideo?: string;
  playIconColour?: string;
  pauseIconColour?: string;
  buttons?: {
    text: string;
    link: string;
    target?: string;
  }[];
  overlayOpacity?: number; // Value between 0 and 1
  position?: string;
  page?: string;
  windLinks?: boolean;
}
interface Props {
  content: VideoContent;
}

const { content } = Astro.props;
const opacity = content.overlayOpacity ?? 1; // Default opacity if not specified
const myVideo = content.backgroundVideo;
const mobileVideo = content.mobileVideo;
const tabletVideo = content.tabVideo
const overlayPosition = content.position || "justify-center";
const iconColor = content.playIconColour || "blue";
const pauseIconColour = content.pauseIconColour || "blue";
var playIcon = "boxicons--play-circle";
var pauseIcon = "boxicons--pause-circle";

if (iconColor === "white") {
   playIcon = "boxicons--play-circle-vit";
} else if(iconColor === "blue") {
   playIcon = "boxicons--play-circle";
} 
if (pauseIconColour === "white") {
   pauseIcon = "boxicons--pause-circle-vit";
} else if(pauseIconColour === "blue") {
   pauseIcon = "boxicons--pause-circle";
}

const pageLink = content.page;
const currentPage = content.page;
---

<astro-page data-page={currentPage}></astro-page>
<section class="videohero">
  <div class="absolute inset-0 left-0 top-0 w-full h-screen overflow-hidden">
    <video id="fullscreenV"   loop muted playsinline  class="hidden md:block min-h-full w-full object-cover" >
      <source src={myVideo} type="video/mp4" />
    </video>
    {tabletVideo && (
      <video  id="tabV" loop muted playsinline class="hidden sm:block md:hidden min-h-full w-full object-cover">
        <source src={tabletVideo} type="video/mp4" />
      </video>
    )}
    {
      mobileVideo && (
        <video  id="mobileV" loop muted playsinline class="sm:hidden min-h-full w-full object-cover">
          <source src={mobileVideo} type="video/mp4" />
        </video>
      )
    }
   <!--  <video  autoplay loop muted playsinline class="hidden md:block lg:hidden min-h-full w-full object-cover">
      <source src={tabletVideo} type="video/mp4" />
    </video>

    <video  autoplay loop muted playsinline class="md:hidden min-h-full w-full object-cover">
      <source src={mobileVideo} type="video/mp4" />
    </video> -->
  </div>
  {content.windLinks && <WindLinks />}
 

  <div    class="hero-background absolute inset-0 left-0 top-0 h-screen lg:w-full lg:h-full overflow-hidden"   style={`opacity: ${opacity};`}  >
    
  </div>
  
  <!-- logo and text overlay -->
  <div  class="site-container mx-auto px-4 pt-0 pb-20 relative z-10 flex flex-col justify-center h-screen items-center  sm:text-center"  class:list={overlayPosition}  >
   <Icon id="deskVBTN" type="button" name={playIcon} class="hidden md:block transition-opacity duration-100 opacity-90  text-9xl  cursor-pointer" onclick="playPause(deskV)"/> 
   <Icon id="mobVBTN" type="button" name={playIcon} class="sm:hidden transition-opacity duration-100 opacity-90  text-8xl cursor-pointer" onclick="playPause(mobV)"/>
    <Icon id="tabVBTN" type="button" name={playIcon} class="hidden sm:block md:hidden transition-opacity duration-100 opacity-90  text-9xl cursor-pointer" onclick="playPause(tabV)"/>
   {
      content.descriptionImage && (
        <div class="">
          <Image
            src={content.descriptionImage}
            alt="Skysport Skärmflygskola"
            width={486}
            height={280}
            class=" invisible md:visible"
            quality={90}
            format="webp"
            loading="lazy"
          />
        </div>
      )
    }
    <p class="text-center text-white text-4xl text-balance">{content.title}</p>
    <p class="text-center text-white mt-2 text-balance">
      {content.description} 
    </p>
    {
      content.buttons && content.buttons.length > 0 && (
        <div class="flex  flex-col md:flex-row gap-4 mt-8 items-center">
          {content.buttons.map((button) => (
            <Button
              href={button.link}
              target={button.target || "_self"}
              variant={button.variant || "primary"}
            >
              {button.text}
            </Button>
          ))}
        </div>
      )
    }
     <div class="absolute z-20 bottom-0 flex justify-end mt-auto mb-0">
       <Icon id="deskVPause" type="button" name={pauseIcon} class="hidden md:block transition-opacity duration-100 opacity-0  text-9xl   justify-end cursor-pointer" onclick="playPause(deskV)"/> 
       <Icon id="mobVPause" type="button" name={pauseIcon} class="sm:hidden transition-opacity duration-100 opacity-0   text-8xl  justify-end cursor-pointer" onclick="playPause(mobV)"/> 
       <Icon id="tabVPause" type="button" name={pauseIcon} class="hidden sm:block md:hidden transition-opacity duration-100 opacity-0   text-9xl  justify-end cursor-pointer" onclick="playPause(tabV)"/> 
  </div>
  </div>
 
</section>

<script is:inline>
   var deskV = document.getElementById("fullscreenV");
   var tabV = document.getElementById("tabV");
   var mobV = document.getElementById("mobileV");

  function fadeOutFunc(item) {
  var el = document.getElementById(item);
  el.style.opacity = 1; 
  var tick = function() {
    el.style.opacity = +el.style.opacity - 0.01;
    if (+el.style.opacity > 0) {
      (window.requestAnimationFrame && requestAnimationFrame(tick)) || setTimeout(tick, 16)
    }
  };
  tick();
}
function fadeInFunc(icony) {
  var el = document.getElementById(icony);
  el.style.opacity = 0; 
  var tick = function() {
    el.style.opacity = +el.style.opacity + 0.01;
    if (+el.style.opacity < 1) {
      (window.requestAnimationFrame && requestAnimationFrame(tick)) || setTimeout(tick, 16)
    }
  };
  tick();
}

function playPause(vidView) { 
  if (vidView.paused){
    vidView.play();
    if(vidView === deskV) {
      fadeOutFunc("deskVBTN"); 
      fadeInFunc("deskVPause"); 
    } else if(vidView === mobV) {
      fadeOutFunc("mobVBTN"); 
      fadeInFunc("mobVPause"); 
    } else if(vidView === tabV) {
       fadeOutFunc("tabVBTN"); 
      fadeInFunc("tabVPause"); 
    }
    fadeOutFunc("deskVBTN"); 
    fadeOutFunc("mobVBTN"); 
    fadeInFunc("deskVPause"); 
  } else {
    vidView.pause();
    if(vidView === deskV) {
      fadeInFunc("deskVBTN"); 
      fadeOutFunc("deskVPause"); 
    } else if(vidView === mobV) {
      fadeInFunc("mobVBTN"); 
      fadeOutFunc("mobVPause"); 
    } else if(vidView === tabV) {
       fadeInFunc("tabVBTN"); 
      fadeOutFunc("tabVPause"); 
    }
    fadeInFunc("deskVBTN");
    fadeOutFunc("deskVPause"); 
  }
} 

</script>

